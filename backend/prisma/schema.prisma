generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ApiKeys {
  id String @id @default(ulid())
  merchantId String
  apiKey String
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  revokedAt  DateTime?
}